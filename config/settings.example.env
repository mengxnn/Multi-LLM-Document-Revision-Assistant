# Copy this file to config/settings.env, then fill in your real keys.
# Keep the names on the left unchanged; replace the values on the right.
#
# Writer and reviewer can use different platforms, keys, and models.

# --- Writer model settings ---
WRITER_API_KEY=replace-with-writer-api-key
WRITER_BASE_URL=
WRITER_MODEL=gpt-4.1
WRITER_ENABLE_SEARCH=false
WRITER_TIMEOUT_SECONDS=60
WRITER_MAX_RETRIES=1
WRITER_MODEL_FAMILY=unknown
WRITER_VISION=false
WRITER_FUNCTION_CALLING=false
WRITER_JSON_OUTPUT=false
WRITER_STRUCTURED_OUTPUT=false

# --- Reviewer model settings ---
REVIEWER_API_KEY=replace-with-reviewer-api-key
REVIEWER_BASE_URL=
REVIEWER_MODEL=gpt-4.1
REVIEWER_ENABLE_SEARCH=false
REVIEWER_TIMEOUT_SECONDS=60
REVIEWER_MAX_RETRIES=1
REVIEWER_MODEL_FAMILY=unknown
REVIEWER_VISION=false
REVIEWER_FUNCTION_CALLING=false
REVIEWER_JSON_OUTPUT=false
REVIEWER_STRUCTURED_OUTPUT=false

# Optional fallback. Leave empty unless you want both roles to share one setting.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ENABLE_SEARCH=false
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=1
